
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model User{
  id String @id @default(uuid())
  username String
  email String @unique
  role Role @default(USER)
  googleId String @unique
  profilePicture String?
  isEmailVerified Boolean @default(true)
  comments Comment[]
  likes Like[]
  opinions UnpopularOpinion[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  newsletterSubscriber NewsletterSubscriber?
}

enum Role {
  USER
  ADMIN
}

model Quotes{
  id String @id @default(uuid())
  quote String
  author String
  rank Int @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id            String      @id @default(uuid())
  title         String
  content       String
  
  directedBy    String
  genres        String[]
  
  language      String @default("English")

  images        PostImage[]
  comments      Comment[]
  likes         Like[]
  viewCount     Int         @default(0)
  adminId       Int         @default(1)
  year          Int
  ratingCategories Json
  reviewPosterImageUrl String?
  streamingAt   String
  posterImageUrl String?     // Reference to the poster image ID
  relatedPostIds String[]   // Array of related post IDs for "You may also like"
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
}

model byGenres{
  id String @id @default(uuid())
  genre String[]
  directedBy String
  year Int
  posterImageUrl String
  title String
  synopsis String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article{
  id String @id @default(uuid())
  title String
  shortDescription String
  slug String
  author String
  mainImageUrl String
  published Boolean @default(true)
  publishedAt DateTime?
  viewCount Int @default(0)
  mainImagePublicId String?
  images ArticleImage[]
  comments Comment[]
  likes Like[]
  blocks ContentBlock[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentBlock{
  id String @id @default(uuid())
  articleId String
  type BlockType
  content Json
  order Int
  publicId String?

  article Article @relation(fields: [articleId], references: [id],onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([articleId, order])
}

enum BlockType{
  PARAGRAPH
  HEADING
  IMAGE
  LIST
  QUOTE
  DIVIDER
}

model TopPicks{
  id String @id @default(uuid())
  title String
  posterImageUrl String
  genre String
  year Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostImage {
  id        String   @id @default(uuid())
  imageUrl  String
  postId    String
  post      Post     @relation(fields: [postId], references: [id],onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
}
model ArticleImage {
  id String    @id @default(uuid())
  imageUrl String
  articleId String
  article Article @relation(fields: [articleId], references: [id],onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Comment{
  id String @id @default(uuid())
  content String
  userId String
  postId String?
  opinionId String?
  parentCommentId String?
  articleId String?
  replies Comment[] @relation(name: "CommentToComment")
  user User @relation(fields: [userId], references: [id])
  post Post? @relation(fields: [postId], references: [id],onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id],onDelete: Cascade)
  opinion UnpopularOpinion? @relation(fields: [opinionId], references: [id])
  parentComment Comment? @relation("CommentToComment",fields: [parentCommentId],references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Like{
  id String @id @default(uuid())
  userId String
  postId String?
  opinionId String?
  articleId String?
  user User @relation(fields: [userId], references: [id])
  post Post? @relation(fields: [postId], references: [id],onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id],onDelete: Cascade)
  opinion UnpopularOpinion? @relation(fields: [opinionId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, postId])
}

model UnpopularOpinion{
  id String @id @default(uuid())
  userId String
  content String
  genres String[]
  
  user User @relation(fields: [userId], references: [id])
  likes Like[]
  comments Comment[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
}

model TrendingMovie {
  id               Int      @id @default(autoincrement())
  tmdbId           Int      @map("tmdb_id")
  title            String
  posterPath       String?  @map("poster_path")
  backdropPath     String?  @map("backdrop_path")
  overview         String?  @db.Text
  releaseDate      DateTime @map("release_date") @db.Date
  voteAverage      Decimal  @map("vote_average") @db.Decimal(3, 1)
  voteCount        Int      @map("vote_count")
  popularityScore  Decimal  @map("popularity_score") @db.Decimal(10, 2)
  trendingRank     Int      @map("trending_rank")
  genreIds         String   @map("genre_ids") // JSON as string - you can use Json type for PostgreSQL
  lastUpdated      DateTime @map("last_updated") @default(now())
  createdAt        DateTime @map("created_at") @default(now())

  @@index([tmdbId])
  @@index([trendingRank])
  @@index([lastUpdated])
  @@map("trending_movies")
}

model TrendingNews {
  id            Int      @id @default(autoincrement())
  title         String
  description   String   @db.Text
  content       String?  @db.Text
  url           String   @unique
  sourceName    String   @map("source_name")
  author        String?
  publishedAt   DateTime @map("published_at")
  imageUrl      String?  @map("image_url")
  category      String
  trendingScore Int?     @map("trending_score")
  lastUpdated   DateTime @map("last_updated") @default(now())
  createdAt     DateTime @map("created_at") @default(now())

  @@index([publishedAt])
  @@index([lastUpdated])
  @@index([category])
  @@map("trending_news")
}

enum ContentType { 
  discussion
  recommendation
  analysis
  matchup
}

enum ContentStatus {
  active
  archived
  draft
}

model AITrendingContent {
  id              Int           @id @default(autoincrement())
  title           String
  content         String        @db.Text
  contentType     ContentType   @map("content_type")
  promptUsed      String?       @map("prompt_used") @db.Text
  status          ContentStatus @default(active)
  viewCount       Int           @map("view_count") @default(0)
  engagementScore Decimal?      @map("engagement_score") @db.Decimal(5, 2)
  expiresAt       DateTime?     @map("expires_at")
  createdAt       DateTime      @map("created_at") @default(now())
  updatedAt       DateTime      @map("updated_at") @updatedAt

  @@index([contentType])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("ai_trending_content")
}

enum SectionType {
  movies
  news
  ai
}

enum RefreshStatus {
  success
  failed
  in_progress
}

model ContentRefreshLog {
  id                    Int           @id @default(autoincrement())
  sectionType           SectionType   @map("section_type")
  lastRefreshAttempt    DateTime      @map("last_refresh_attempt") @default(now())
  lastSuccessfulRefresh DateTime?     @map("last_successful_refresh")
  status                RefreshStatus
  errorMessage          String?       @map("error_message") @db.Text
  recordsUpdated        Int?          @map("records_updated")

  @@index([sectionType])
  @@index([lastSuccessfulRefresh])
  @@index([status])
  @@map("content_refresh_log")
}


//Newsletter



// ─── ENUMS ───────────────────────────────────────────────

enum NewsletterType {
  BOLLYWOOD
  HOLLYWOOD
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
}

enum SubscriberStatus {
  PENDING        // signed up, payment not completed yet
  ACTIVE         // paying, receiving emails
  PAST_DUE       // payment failed, in retry window
  CANCELED       // fully canceled, no access
  UNSUBSCRIBED   // opted out of emails manually
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum InvoiceStatus {
  PAID
  OPEN
  FAILED
  VOID
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
}

enum EmailLogStatus {
  QUEUED
  SENT
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED   // SES complaint — critical to track
  FAILED
}

// ─── NEWSLETTER PLAN ─────────────────────────────────────

// One row per plan. You'll have at least:
// - Bollywood Monthly, Bollywood Yearly
// - Hollywood Monthly, Hollywood Yearly
// Pricing is DB-driven so you can change it without redeploying

model NewsletterPlan {
  id                String          @id @default(uuid())
  name              String          // e.g. "Bollywood Weekly"
  description       String?
  type              NewsletterType
  billingInterval   BillingInterval
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("inr") // inr for Razorpay, usd for Stripe
  isActive          Boolean         @default(true)  // set false to retire a plan

  // Provider-side plan/price IDs
  // These are created on Stripe/Razorpay dashboards and stored here
  stripePriceId     String?         // Stripe Price ID e.g. price_xxxxx
  razorpayPlanId    String?         // Razorpay Plan ID e.g. plan_xxxxx

  subscriptions     NewsletterSubscription[]
  campaigns         NewsletterCampaign[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

// ─── NEWSLETTER SUBSCRIBER ───────────────────────────────

// Core identity table. One row per email address.
// userId is optional — someone can subscribe without a Google account

model NewsletterSubscriber {
  id                String             @id @default(uuid())
  email             String             @unique
  name              String?

  // Optional link to your existing User model
  userId            String?            @unique
  user              User?              @relation(fields: [userId], references: [id])

  status            SubscriberStatus   @default(PENDING)

  // Country detected from IP during signup
  // Used to route to Stripe (international) or Razorpay (India)
  country           String?            // e.g. "IN", "US"
  provider          PaymentProvider?   // set once they complete payment

  // Unsubscribe — unique token, no auth needed
  // Link format: /unsubscribe?token=xxxx
  unsubscribeToken  String             @unique @default(uuid())
  unsubscribedAt    DateTime?

  // Email verification for non-OAuth subscribers
  confirmToken      String?
  confirmedAt       DateTime?

  subscriptions     NewsletterSubscription[]
  emailLogs         NewsletterEmailLog[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

// ─── NEWSLETTER SUBSCRIPTION ─────────────────────────────

// One row per subscriber per plan.
// A subscriber who wants both Bollywood + Hollywood gets two rows here.

model NewsletterSubscription {
  id                    String           @id @default(uuid())

  subscriberId          String
  subscriber            NewsletterSubscriber @relation(fields: [subscriberId], references: [id])

  planId                String
  plan                  NewsletterPlan   @relation(fields: [planId], references: [id])

  provider              PaymentProvider
  status                PaymentStatus    @default(ACTIVE)

  // ── Stripe fields (populated if provider = STRIPE) ──
  stripeCustomerId      String?
  stripeSubscriptionId  String?          @unique
  stripePaymentMethodId String?          // saved card

  // ── Razorpay fields (populated if provider = RAZORPAY) ──
  razorpayCustomerId    String?
  razorpaySubscriptionId String?         @unique
  razorpayMandateId     String?          // UPI Autopay mandate ID — separate from subscription
  razorpayPaymentMethodType String?      // "upi" | "card" | "emandate"

  // Billing period
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime

  // Cancellation
  cancelAtPeriodEnd     Boolean          @default(false)
  canceledAt            DateTime?

  // Failed payment tracking
  retryCount            Int              @default(0)  // increments on each failed charge
  lastPaymentError      String?          // last error message from provider

  payments              NewsletterPayment[]

  // Ensure one subscription per subscriber per plan
  @@unique([subscriberId, planId])

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

// ─── NEWSLETTER PAYMENT ──────────────────────────────────

// Ledger of every charge attempt, success or failure.
// Never delete rows from here.

model NewsletterPayment {
  id                String           @id @default(uuid())

  subscriptionId    String
  subscription      NewsletterSubscription @relation(fields: [subscriptionId], references: [id])

  provider          PaymentProvider
  status            InvoiceStatus

  amount            Decimal          @db.Decimal(10, 2)
  currency          String

  // Provider-side invoice/payment IDs
  stripeInvoiceId   String?          @unique
  stripePaymentIntentId String?

  razorpayPaymentId String?          @unique  // e.g. pay_xxxxx
  razorpayInvoiceId String?          // e.g. inv_xxxxx if using Razorpay invoices

  paidAt            DateTime?
  failureReason     String?          // populated on failed payments

  createdAt         DateTime         @default(now())
}

// ─── NEWSLETTER CAMPAIGN ─────────────────────────────────

// Each issue/edition you send out.
// Linked to a plan — Bollywood campaign only goes to Bollywood subscribers.

model NewsletterCampaign {
  id              String           @id @default(uuid())

  planId          String
  plan            NewsletterPlan   @relation(fields: [planId], references: [id])

  subject         String
  previewText     String?          // the snippet shown in email clients before opening

  // The actual newsletter content — stored as JSON
  // Maps to your HTML template sections:
  // { spotlight: {...}, releases: [...], editorial: {...}, hiddenGem: {...}, etc. }
  content         Json

  status          CampaignStatus   @default(DRAFT)
  scheduledAt     DateTime?        // when to send, null = send immediately
  sentAt          DateTime?        // populated once sending completes

  // Stats — denormalized for quick admin dashboard reads
  totalRecipients Int              @default(0)
  totalSent       Int              @default(0)
  totalOpened     Int              @default(0)
  totalClicked    Int              @default(0)
  totalBounced    Int              @default(0)

  emailLogs       NewsletterEmailLog[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

// ─── NEWSLETTER EMAIL LOG ────────────────────────────────

// One row per email per campaign per subscriber.
// Critical for SES compliance — bounces and complaints must be tracked
// or AWS will suspend your sending.

model NewsletterEmailLog {
  id              String           @id @default(uuid())

  subscriberId    String
  subscriber      NewsletterSubscriber @relation(fields: [subscriberId], references: [id])

  campaignId      String
  campaign        NewsletterCampaign @relation(fields: [campaignId], references: [id])

  // SES Message ID — returned when you call SES SendEmail
  // Used to match SNS bounce/complaint notifications back to this row
  sesMessageId    String?          @unique

  status          EmailLogStatus   @default(QUEUED)

  sentAt          DateTime?
  openedAt        DateTime?        // requires SES open tracking pixel
  clickedAt       DateTime?        // requires SES click tracking
  bouncedAt       DateTime?
  complainedAt    DateTime?        // user hit spam — remove from all future sends immediately

  // Bounce details from SNS notification
  bounceType      String?          // "Permanent" | "Transient"
  bounceSubType   String?          // "NoEmail" | "Suppressed" | "MailboxFull" etc.

  createdAt       DateTime         @default(now())

  @@index([subscriberId])
  @@index([campaignId])
  @@index([sesMessageId])
  @@index([status])
}